<santa xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:noNamespaceSchemaLocation="santa.xsd">

    <!-- Number of replicates -->
    <replicates>10</replicates>

    <simulation>
        <!-- Genome definition -->
        <genome>
            <length>1302</length> <!-- Change to your genome length -->

            <!-- Load sequences from a FASTA file -->
            <sequences file="viral_sequences.fasta"/>

            <!-- Single nucleotide feature spanning entire genome -->
            <feature>
                <name>gene1</name>
                <type>nucleotide</type>
                <coordinates>1-1302</coordinates>
            </feature>
        </genome>

        <!-- Population definition -->
        <population>
            <populationSize>1000</populationSize> <!-- Number of individuals -->
            <inoculum>all</inoculum> <!-- Initialize from sequences provided -->
        </population>

        <!-- Neutral fitness function -->
        <fitnessFunction>
            <neutralFitness />
        </fitnessFunction>

        <!-- Replicator definition: recombinant -->
        <replicator>
            <recombinantReplicator>
                <dualInfectionProbability>0.05</dualInfectionProbability>
                <recombinationProbability>0.001</recombinationProbability>
            </recombinantReplicator>
        </replicator>

        <!-- Mutator definition: nucleotide mutations -->
        <mutator>
            <nucleotideMutator>
                <mutationRate>0.001</mutationRate>
                <transitionBias>2.0</transitionBias>
            </nucleotideMutator>
        </mutator>

        <!-- Simulation epoch -->
        <epoch>
            <name>default epoch</name>
            <generationCount>500</generationCount> <!-- Number of generations -->
        </epoch>

        <!-- Sampling schedule -->
        <samplingSchedule>
            <!-- Sample 100 sequences at the last generation -->
            <sampler>
                <atGeneration>500</atGeneration>
                <fileName>alignment_%r.fasta</fileName>
                <alignment>
                    <sampleSize>100</sampleSize>
                    <format>FASTA</format>
                    <label>seq_%g_%s</label>
                </alignment>
            </sampler>

            <!-- Population statistics every 50 generations -->
            <sampler>
                <atFrequency>50</atFrequency>
                <fileName>stats_%r.csv</fileName>
                <statistics />
            </sampler>
        </samplingSchedule>
    </simulation>
</santa>