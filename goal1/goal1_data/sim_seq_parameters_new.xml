<santa xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:noNamespaceSchemaLocation="santa.xsd">

    <!--
    Number of independent simulations to run. Each replicate produces
    its own FASTA alignment and statistics files.
    -->
    <replicates>1</replicates>

    <simulation>

        <!--
        Defines the genome that will evolve in the simulation.
        -->
        <genome>

            <!-- Total length of the genome in nucleotides -->
            <length>2501</length>
              
            <sequences file="base seeds/base_seed_10.fasta"/>

            <!--
            Feature definition:
            - Entire genome treated as one selectable region
            - Coordinates: 1-2501
            - Type: nucleotide (DNA/RNA sequence)
            -->
            <feature>
                <name>genome</name>
                <type>nucleotide</type>
                <coordinates>1-2501</coordinates>
            </feature>

        </genome>

        <!--
        - populationSize: number of individuals in the simulation
        - inoculum: "all" means every genome in the initial population
          starts as a copy of the sequence in the seed file
        -->
        <population>
            <populationSize>100</populationSize>
            <inoculum>all</inoculum>
        </population>

        <!--
        Purifying fitness:
        - 70% of sites under purifying selection, rest neutral
        - Each nucleotide site is ranked by how fit each base is
        - Most fit base = 1.0, less fit = linearly decreasing to lowFitness
        - Sites beyond selection region get neutral fitness
        -->
        <fitnessFunction>

            <purifyingFitness>
                <!-- Feature to apply selection to -->
                <feature>genome</feature>

                <!-- Sites to apply selection to: first 1750 nucleotides -->
                <sites>1-1750</sites>

                <!-- Rank nucleotides by observed frequency -->
                <rank>
                    <order>observed</order>
                    <breakTies>random</breakTies>
                </rank>

                <!-- Fitness decay parameters -->
                <fitness>
                    <lowFitness>0.8</lowFitness>        <!-- second tier fitness -->
                    <minimumFitness>0.2</minimumFitness> <!-- lethal tier -->
                </fitness>

            </purifyingFitness>

            <neutralFitness>
                <!-- Remaining 30% of genome is neutral -->
                <feature>genome</feature>
                <sites>1751-2501</sites>
            </neutralFitness>

        </fitnessFunction>

        <!--
        Allows two genomes to recombine during replication if they co-infect.
        Parameters:
        - dualInfectionProbability: chance that a host has two genomes for recombination
        - recombinationProbability: chance of crossover per replication event
        -->
        <replicator>
            <recombinantReplicator>
                <dualInfectionProbability>0.1</dualInfectionProbability>
                <recombinationProbability>0.005</recombinationProbability>
            </recombinantReplicator>
        </replicator>

        <!--
        Controls how genomes mutate each generation.
        Parameters:
        - mutationRate: per-site mutation probability per generation
          (0.002 = 0.2% chance per nucleotide per generation)
        - transitionBias: transitions occur twice as often as transversions
        -->
        <mutator>
            <nucleotideMutator>
                <mutationRate>0.002</mutationRate>
                <transitionBias>2.0</transitionBias>
            </nucleotideMutator>
        </mutator>

        <!--
        Defines the duration of the simulation.
        - generationCount: total number of generations to simulate.
          Here: 5000 generations for sufficient accumulation of mutations
          and recombination events.
        -->
        <epoch>
            <name>selection evolution</name>
            <generationCount>5000</generationCount>
        </epoch>

        <!--
        Specifies when and how to sample genomes from the population.
        -->
        <samplingSchedule>

            <!-- 
            Sample entire population at the final generation.
            There is only one replicate per run because each run is evolving from a different base sequence.
            -->
            <sampler>
                <atGeneration>5000</atGeneration>
                <fileName>replicate_10.fasta</fileName>
                <alignment>
                    <!-- Sample size: how many genomes to include in the alignment -->
                    <sampleSize>100</sampleSize>
                    <format>FASTA</format>
                    <!-- Labels for each sequence in the alignment -->
                    <label>seq_10_%s</label>
                </alignment>
            </sampler>
               
            <sampler>
                <atGeneration>5000</atGeneration>
                <fileName>stats_10.csv</fileName>
                <statistics />
            </sampler>

        </samplingSchedule>

    </simulation>

</santa>
